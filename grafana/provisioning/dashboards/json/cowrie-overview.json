{
  "title": "Cowrie Honeypot Overview",
  "uid": "cowrie-overview",
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "exclude_ip",
        "type": "textbox",
        "label": "Exclude IP (optional)",
        "description": "Set this to your own IP to hide your own testing/admin traffic from every panel below.",
        "query": "",
        "current": { "text": "__EXCLUDE_IP_PLACEHOLDER__", "value": "__EXCLUDE_IP_PLACEHOLDER__" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Connections Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "count_over_time({job=\"cowrie\"} | json | eventid=\"cowrie.session.connect\" | src_ip != \"$exclude_ip\" [5m])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Commands Typed by Attackers",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{job=\"cowrie\"} | json | eventid=\"cowrie.command.input\" | src_ip != \"$exclude_ip\" | line_format \"{{.src_ip}} ran: {{.input}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Top Source IPs",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "topk(10, sum by (src_ip) (count_over_time({job=\"cowrie\"} | json | eventid=\"cowrie.session.connect\" | src_ip != \"$exclude_ip\" [6h])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Threat Intel \u2014 AbuseIPDB Enrichment",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{service=\"cloud-siem-threat-intel\"} | json | src_ip != \"$exclude_ip\"",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "json"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "tsNs": true,
              "id": true,
              "labels": true,
              "Time": true,
              "total_reports": true
            },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ]
          },
    {
      "id": 5,
      "title": "Web Honeypot — Requests Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 34 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "count_over_time({job=\"isc-agent\"} | json | sip != \"$exclude_ip\" [5m])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Web Honeypot — Top Requested Paths",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 42 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "topk(10, sum by (url) (count_over_time({job=\"isc-agent\"} | json | sip != \"$exclude_ip\" [6h])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Web Honeypot — Top Source IPs",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 50 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "topk(10, sum by (sip) (count_over_time({job=\"isc-agent\"} | json | sip != \"$exclude_ip\" [6h])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Web Honeypot — Raw Request Log",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 58 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{job=\"isc-agent\"} | json | sip != \"$exclude_ip\" | line_format \"{{.sip}} {{.method}} {{.url}} UA={{.useragent}}\"",
          "refId": "A"
        }
      ]
    }
  ]
} 
